{
  "name": "astro-website-template",
  "version": "1.0.0-beta.52",
  "description": "Astro Website Template",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:cloudflare": "astro build && npx wrangler dev --port 3010",
    "preview:cloudflare:https": "astro build && npx wrangler dev --local-protocol https --port 3010",
    "preview:cloudflare:staging": "astro build && npx wrangler dev -e staging --port 3011",
    "deploy": "astro build && npx wrangler deploy",
    "deploy:staging": "astro build && npx wrangler deploy -e staging",
    "deploy:pages": "astro build && npx wrangler pages deploy ./dist",
    "astro": "astro",
    "check": "pnpm run check:astro && pnpm run check:eslint && pnpm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint src/",
    "check:prettier": "prettier --check .",
    "fix": "pnpm run fix:eslint && pnpm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "storyblok:sync": "node scripts/storyblok-types/cli.js sync",
    "storyblok:fetch": "node scripts/storyblok-types/cli.js fetch",
    "storyblok:generate": "node scripts/storyblok-types/cli.js generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@algolia/requester-fetch": "^4.25.2",
    "@astrojs/cloudflare": "^12.6.0",
    "@astrojs/prism": "^3.3.0",
    "@astrojs/react": "^4.4.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/vercel": "^8.2.7",
    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/inter": "^5.2.5",
    "@react-pdf/renderer": "^4.3.1",
    "@storyblok/astro": "^7.3.0",
    "@storyblok/js": "^4.2.0",
    "@storyblok/richtext": "^3.5.0",
    "@tailwindcss/forms": "^0.5.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "algoliasearch": "^4.24.0",
    "astro": "^5.7.3",
    "astro-embed": "^0.9.0",
    "astro-icon": "^1.1.5",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.2",
    "instantsearch.js": "^4.73.3",
    "js-cookie": "^3.0.5",
    "limax": "4.1.0",
    "linkedom": "^0.18.12",
    "lodash.merge": "^4.6.2",
    "node-html-markdown-cloudflare": "^1.3.0",
    "postmark": "^4.0.5",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satori": "^0.10.13",
    "satori-html": "^0.3.2",
    "storyblok-js-client": "^7.1.5",
    "storyblok-rich-text-astro-renderer": "^2.8.0",
    "turndown": "^7.2.1",
    "unpic": "^4.1.2",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.2.4",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/tailwind": "^5.1.5",
    "@eslint/js": "^9.24.0",
    "@iconify-json/flat-color-icons": "^1.2.1",
    "@iconify-json/tabler": "^1.2.17",
    "@tailwindcss/typography": "^0.5.16",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "astro-compress": "2.3.8",
    "astro-eslint-parser": "^1.2.2",
    "axios": "^1.12.2",
    "commander": "^14.0.1",
    "eslint": "^9.24.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.0.0",
    "js-yaml": "^4.1.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sass-embedded": "^1.93.2",
    "sharp": "0.34.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "unist-util-visit": "^5.0.0",
    "vite": "^6.3.6",
    "vite-plugin-mkcert": "^1.17.8",
    "vitest": "^3.2.4",
    "wrangler": "^4.37.1"
  }
}
