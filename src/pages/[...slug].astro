---
import { getLiveStory, type ISbStoryData, type SbBlokData } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import Layout from '~/layouts/Layout.astro';
import type { StoryblokStory } from '~/types/storyblok';
import type { StoryblokPageComponent } from '~/types/storyblok.custom';
import { getGlobalSettingsStory, getStoryblokStoryWithRelations } from '~/utils/storyblokRepository';
import {
  RESOLVED_RELATIONS_ARRAY,
  getStoryblokVersion,
  AVAILABLE_LANGUAGES,
} from '~/utils/storyblokRepository/helpers';

const slug = Astro.params.slug?.split('/') ?? [];
const language = AVAILABLE_LANGUAGES.includes(slug[0]) ? slug[0] : undefined;
if (language) {
	slug.shift();
}

const storySlug = slug.join('/') || 'home';
const storyblokVersion = getStoryblokVersion(Astro.cookies);

let story: StoryblokStory<StoryblokPageComponent> | null = null;
let globalSettingsStory: Awaited<ReturnType<typeof getGlobalSettingsStory>> = null;

let error: Error | null = null;

try {
  const storyRequest = getStoryblokStoryWithRelations<StoryblokPageComponent>(
    storySlug,
    {
      resolve_relations: RESOLVED_RELATIONS_ARRAY,
      version: storyblokVersion,
      language: language,
    }
  );
  const globalSettingsStoryRequest = getGlobalSettingsStory({
    version: storyblokVersion,
    language: language,
  });
  [story, globalSettingsStory] = await Promise.all([storyRequest, globalSettingsStoryRequest]);
} catch (e) {
  error = e as Error;
  console.error('Error fetching content:', e);
}

let liveStory: ISbStoryData | null = null;
if (storyblokVersion === 'draft') liveStory = await getLiveStory(Astro);
if (liveStory) story = liveStory as StoryblokStory<StoryblokPageComponent>;

if (!story) {
  return new Response(null, {
    status: 404,
    statusText: 'Not Found',
  });
}

if (!globalSettingsStory) {
  console.warn('Failed to fetch global settings, using fallback data:', error);
  globalSettingsStory = null;
}
---

{
  story && story.content && (
    <StoryblokComponent
      storyUUID={story.uuid}
      blok={story.content as SbBlokData}
      globalSettingsStory={globalSettingsStory}
    />
  )
}

{
  error && (
    <Layout blok={story.content} globalSettingsStory={globalSettingsStory}>
      <main>
        <div class="px-4 py-3 m-4 text-red-700 bg-red-100 rounded border border-red-400">
          <h2 class="font-bold">Error loading content</h2>
          <p>Could not load content from Storyblok. Please check your configuration.</p>
          <details class="mt-2">
            <summary class="cursor-pointer">Show error details</summary>
            <pre class="mt-2 text-xs">{error.message}</pre>
          </details>
        </div>
      </main>
    </Layout>
  )
}
