---
import SwitchField from "~/components/ui/SwitchField.astro";
import Typography from "~/components/ui/typography/Typography.astro";
import type { ContactCenteredStoryblok } from "~/types/storyblok";
import type { BlokProps } from "~/types/storyblok.custom";
import { makeEditable } from "~/utils/storyblokRepository/helpers";

type Props = BlokProps<ContactCenteredStoryblok>;

const { blok } = Astro.props;
const { title, description, firstNameLabel, lastNameLabel, companyLabel, phoneNumberLabel, emailLabel, messageLabel, toggleText, buttonText } = blok;
---

<div class="overflow-hidden bg-white py-16 px-4 sm:px-6 lg:px-8 lg:py-24" {...makeEditable(blok)}>
  <div class="relative mx-auto max-w-xl">
    <svg class="absolute left-full translate-x-1/2 transform" width="404" height="404" fill="none" viewBox="0 0 404 404" aria-hidden="true">
      <defs>
        <pattern id="85737c0e-0916-41d7-917f-596dc7edfa27" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <rect x="0" y="0" width="4" height="4" class="text-gray-200" fill="currentColor" />
        </pattern>
      </defs>
      <rect width="404" height="404" fill="url(#85737c0e-0916-41d7-917f-596dc7edfa27)" />
    </svg>
    <svg class="absolute right-full bottom-0 -translate-x-1/2 transform" width="404" height="404" fill="none" viewBox="0 0 404 404" aria-hidden="true">
      <defs>
        <pattern id="85737c0e-0916-41d7-917f-596dc7edfa27" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <rect x="0" y="0" width="4" height="4" class="text-gray-200" fill="currentColor" />
        </pattern>
      </defs>
      <rect width="404" height="404" fill="url(#85737c0e-0916-41d7-917f-596dc7edfa27)" />
    </svg>
    <div class="text-center">
      <Typography as="h2" variant="h2" class="text-primary-900">{title}</Typography>
      <p class="mt-4 text-lg leading-6 text-primary-700">{description}</p>
    </div>
    <div class="mt-12">
      <form class="grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-8" method="post" action="#">
        <div>
          <label for="first-name" class="block text-sm font-medium text-gray-700">{firstNameLabel || 'First Name'}</label>
          <div class="mt-1">
            <input type="text" name="firstName" id="first-name" autocomplete="given-name" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" />
          </div>
        </div>
        <div>
          <label for="last-name" class="block text-sm font-medium text-gray-700">{lastNameLabel || 'Last Name'}</label>
          <div class="mt-1">
            <input type="text" name="lastName" id="last-name" autocomplete="family-name" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" />
          </div>
        </div>
        <div>
          <label for="company" class="block text-sm font-medium text-gray-700">{companyLabel || 'Company'}</label>
          <div class="mt-1">
            <input type="text" name="company" id="company" autocomplete="organization" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" />
          </div>
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">{emailLabel || 'Email'}</label>
          <div class="mt-1">
            <input type="email" name="email" id="email" autocomplete="email" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" />
          </div>
        </div>
        <div class="sm:col-span-2">
          <label for="phone-number" class="block text-sm font-medium text-gray-700">{phoneNumberLabel || 'Phone Number'}</label>
          <div class="mt-1">
            <input type="text" name="phoneNumber" id="phone-number" autocomplete="tel" placeholder="+1 (555) 987-6543" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" />
          </div>
        </div>
        <div class="sm:col-span-2">
          <label for="message" class="block text-sm font-medium text-gray-700">{messageLabel || 'Message'}</label>
          <div class="mt-1">
            <textarea id="message" name="message" rows="4" class="block w-full rounded-md border border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm"></textarea>
          </div>
        </div>
        <SwitchField id="agreed" name="agreed" text={toggleText} />
        <div class="sm:col-span-2">
          <button type="submit" class=" w-full justify-center bg-primary-600 px-6 py-3  text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 disabled:border-transparent disabled:bg-primary-200 disabled:hover:bg-primary-200" disabled data-submit-button>
            {buttonText || 'Submit'}
          </button>
        </div>
      </form>
      <script>
        let cleanup: (() => void) | null = null;

        function init() {
          const switchRoot = document.querySelector('[data-switch-id="agreed"]');
          const submitButton = document.querySelector('[data-submit-button]') as HTMLButtonElement | null;
          if (!switchRoot || !submitButton) return () => {};

          const onChange = (e: Event) => {
            const { detail } = e as CustomEvent<{ checked?: boolean }>;
            if (detail && typeof detail.checked === 'boolean') {
              submitButton.disabled = !detail.checked;
            }
          };

          // Initialize button state from current input value
          const input = switchRoot.querySelector('input[type="checkbox"]') as HTMLInputElement | null;
          if (input) submitButton.disabled = !input.checked;

          switchRoot.addEventListener('switchChange', onChange as EventListener);

          return () => {
            switchRoot.removeEventListener('switchChange', onChange as EventListener);
          };
        }

        document.addEventListener('astro:page-load', () => {
          if (cleanup) cleanup();
          cleanup = init();
        });

        document.addEventListener('astro:before-swap', () => {
          if (cleanup) cleanup();
          cleanup = null;
        });
      </script>
    </div>
  </div>
</div>
---