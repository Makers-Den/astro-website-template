---

import StoryblokImage from '~/components/ui/StoryblokImage.astro';
import UnstyledLink from '~/components/ui/UnstyledLink.astro';
import 
  Typography
from '~/components/ui/typography/Typography.astro';
import type { ArticleCardStoryblok, AuthorStoryblok, CategoryStoryblok, PostStoryblok, StoryblokStory } from '~/types/storyblok';
import type { BlokProps } from '~/types/storyblok.custom';
import { ensurePreceedingSlash, getFormattedDate } from '~/utils/helpers';
import { getStoryblokStories, getStoryblokStory } from '~/utils/storyblokRepository';
import { getStoryblokVersion, isStoryResolved, makeEditable } from '~/utils/storyblokRepository/helpers';

type Props = BlokProps<ArticleCardStoryblok>;
const { blok } = Astro.props;
const { post } = blok;

const storyblokVersion = getStoryblokVersion(Astro.cookies);


let resolvedPost: StoryblokStory<PostStoryblok> | string | undefined | null = post;

if (resolvedPost && !isStoryResolved(resolvedPost)) {
  try {
    resolvedPost = await getStoryblokStory<PostStoryblok>(resolvedPost, {
      find_by: 'uuid',
      version: storyblokVersion,
    });
  } catch (error) {
    resolvedPost = null;
    console.error('Error fetching post:', error);
  }
}

let resolvedAuthor: StoryblokStory<AuthorStoryblok> | string | undefined | null = null;
let resolvedCategories: Array<StoryblokStory<CategoryStoryblok> | string> | undefined | null = null;

if (resolvedPost && isStoryResolved(resolvedPost)) {
  resolvedAuthor = resolvedPost.content.author;
  resolvedCategories = resolvedPost.content.categories;

  if (resolvedAuthor && !isStoryResolved(resolvedAuthor)) {
  try {
    resolvedAuthor = await getStoryblokStory<AuthorStoryblok>(resolvedAuthor, {
      find_by: 'uuid',
      version: storyblokVersion,
    });
  } catch (error) {
    resolvedAuthor = null;
    console.error('Error fetching author:', error);
  }
  }
  if (resolvedCategories && !isStoryResolved(resolvedCategories[0])) {
    try {
      resolvedCategories = await getStoryblokStories<StoryblokStory<CategoryStoryblok>>({
      by_uuids: resolvedCategories.join(','),
      version: storyblokVersion,
    });
    } catch (error) {
      resolvedCategories = null;
      console.error('Error fetching categories:', error);
    }
  }

}

---

{resolvedPost && isStoryResolved(resolvedPost) && resolvedAuthor && isStoryResolved(resolvedAuthor) && <>
<div class='flex flex-col overflow-hidden rounded-lg shadow-lg' {...makeEditable(blok)}>
      <div class='flex-shrink-0'>
        <StoryblokImage
          class='h-48 w-full object-cover'
          src={resolvedPost.content?.image?.filename}
          alt={resolvedPost.content?.image?.alt}
        />
      </div>
      <div class='flex flex-1 flex-col justify-between bg-white p-6'>
        <div class='flex-1'>
          <UnstyledLink
            href={ensurePreceedingSlash(resolvedPost.full_slug)}
            class='hover:underline'
          >
            <Typography as="p" variant="bodySmall" class='font-medium text-primary-800'>
              {isStoryResolved(resolvedCategories?.[0])
                ? resolvedCategories[0].name
                : 'Choose a category '}
            </Typography>
          </UnstyledLink>
          

          <div class='mt-2 block'>
              <UnstyledLink href={ensurePreceedingSlash(resolvedPost.full_slug)}>
                <Typography as="h4" variant="h4" class='font-semibold text-gray-900'>
                  {resolvedPost.content?.title || 'Fill a title'}
                </Typography>
              </UnstyledLink>
              <UnstyledLink href={ensurePreceedingSlash(resolvedPost.full_slug)}>
                <Typography as="p" variant="body" class='mt-3 text-primary-700'>
                  {resolvedPost.content?.intro}
                </Typography>
              </UnstyledLink>
          </div>
        </div>
        <div class='mt-6 flex items-center'>
          <div class='flex-shrink-0'>
            <UnstyledLink href='#'>
              {resolvedAuthor.content.image ? (
                <StoryblokImage
                    class='rounded-full'
                  src={resolvedAuthor.content?.image?.filename}
                  alt={resolvedAuthor.content?.image?.alt}
                  width={40}
                  height={40}
                />
              ) : (
                'Please insert an image'
              )}
            </UnstyledLink>
          </div>
          <div class='ml-3'>
            <UnstyledLink href='#' class='hover:underline'>
              <Typography as="p" variant="bodySmall" class='font-medium text-primary-900'>
                {resolvedAuthor.content?.name}
              </Typography>
            </UnstyledLink>

            <div class='flex space-x-1 text-sm text-primary-700'>
              <time datetime='12-02-2002'>
                {getFormattedDate(resolvedPost.first_published_at)}
              </time>
              <span aria-hidden='true'>&middot;</span>
              <span>5 minutes </span>
            </div>
          </div>
        </div>
      </div>
</>
}
