---
import RichTextRenderer from '~/components/storyblok/utils/RichTextRenderer.astro';
import SvgIcon from '~/components/ui/SvgIcon.astro';
import type { FeatureGridItemStoryblok } from '~/types/storyblok';
import type { BlokProps } from '~/types/storyblok.custom';
import { makeEditable } from '~/utils/storyblokRepository/helpers';

type Props = BlokProps<FeatureGridItemStoryblok>;
const { blok } = Astro.props;
const { title, icon, description } = blok;
---

<div class="pt-6" {...makeEditable(blok)}>
  <div class="flow-root rounded-lg bg-gray-50 px-6 pb-8">
    <div class="-mt-6">
      <div>
        <span class="inline-flex items-center justify-center rounded-md bg-primary-800 p-3 shadow-lg">
          <SvgIcon name={icon || 'Cog'} class="text-white h-6 w-6" />
        </span>
      </div>
      <h3 class="mt-8 text-lg font-medium tracking-tight text-gray-900">{title}</h3>
      <div class="mt-5 text-base text-gray-500">
        <RichTextRenderer content={description} />
      </div>
    </div>
  </div>
</div>
