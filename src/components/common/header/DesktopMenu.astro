---
import NavLinkDesktop from '~/components/common/header/blocks/NavLinkDesktop.astro';
import NavSectionDesktop from '~/components/common/header/blocks/NavSectionDesktop.astro';
import type { NavSectionStoryblok, LinkStoryblok } from '~/types/storyblok';

export interface Props {
  items?: Array<NavSectionStoryblok | LinkStoryblok>;
}

const { items = [] } = Astro.props as Props;
---

<Fragment>
  {
    items.map((blok) => {
      if (blok.component === 'Link') {
        return <NavLinkDesktop blok={blok} />;
      }
      if (blok.component === 'NavSection') {
        return <NavSectionDesktop blok={blok} />;
      }
      return null;
    })
  }
</Fragment>
