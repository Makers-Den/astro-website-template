---
import NavLinkMobile from '~/components/common/header/blocks/NavLinkMobile.astro';
import NavSectionMobile from '~/components/common/header/blocks/NavSectionMobile.astro';
import { clsxm } from '~/utils/helpers';
import type { NavSectionStoryblok, LinkStoryblok } from '~/types/storyblok';
import LocaleSwitcher from '../LocaleSwitcher.astro';

export interface Props {
  items?: Array<NavSectionStoryblok | LinkStoryblok>;
  halfWidth?: boolean;
}

const { items = [], halfWidth = false } = Astro.props as Props;
---

<details class="relative">
  <summary class="inline-flex items-center justify-center focus:ring-2 focus:ring-inset">
    <svg class="block h-6 w-6 group-open:hidden" viewBox="0 0 24 24"
      ><path
        d="M4 6h16M4 12h16M4 18h16"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path></svg
    >
    <svg class="hidden h-6 w-6 group-open:block" viewBox="0 0 24 24"
      ><path
        d="M6 18L18 6M6 6l12 12"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path></svg
    >
  </summary>

  <div
    class={clsxm(
      'lg:hidden',
      'fixed left-0 top-[82px] z-20 md:top-[100px]',
      'h-[calc(100vh-82px)]',
      'bg-white',
      halfWidth ? 'w-[min(100%,max(50%,200px))]' : 'w-full'
    )}
    data-mobile-menu
  >
    <div class="h-full overflow-scroll overscroll-contain px-10 pt-6 pb-3">
      {
        items.map((blok) => {
          if (blok.component === 'Link') {
            return <NavLinkMobile blok={blok} />;
          }
          if (blok.component === 'NavSection') {
            return <NavSectionMobile blok={blok} />;
          }
          return null;
        })
      }

      <LocaleSwitcher className="mt-10" />

      <div class="h-4"></div>
    </div>
  </div>

  <script>
    const root = (document.currentScript?.closest('details') as HTMLDetailsElement) || null;

    function toggleBodyOverflow(open) {
      if (open) {
        document.body.classList.add('overflow-hidden');
      } else {
        document.body.classList.remove('overflow-hidden');
      }
    }

    function syncState() {
      if (!root) return;
      toggleBodyOverflow(root.open);
    }

    function onToggle() {
      syncState();
    }

    document.addEventListener('astro:page-load', () => {
      if (root) {
        root.addEventListener('toggle', onToggle);
        syncState();
      }
    });

    document.addEventListener('astro:before-swap', () => {
      if (root) {
        root.removeEventListener('toggle', onToggle);
        toggleBodyOverflow(false);
      }
    });
  </script>
</details>
